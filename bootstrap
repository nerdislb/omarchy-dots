#!/bin/bash

# Bring an Omarchy machine to this repo's state: copy the tracked files into
# place, then run the setup (Rise bar, weather pin, scrolloverview plugin).
#
# Usage:
#   ./bootstrap --dry-run     # show what would happen, change nothing
#   ./bootstrap               # do it (will prompt for sudo)
#
# Files are COPIED, not symlinked: Omarchy migrations sed -i user configs in
# ~/.config, and sed -i replaces a symlink with a regular file — the repo link
# would break silently. Use ./sync-back to pull local edits back in.

set -uo pipefail

REPO_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
MANIFEST="$REPO_DIR/manifest"

DRY=0
[[ ${1:-} == "--dry-run" || ${1:-} == "-n" ]] && DRY=1

bold=$'\e[1m'; green=$'\e[32m'; yellow=$'\e[33m'; red=$'\e[31m'; reset=$'\e[0m'
step() { printf '\n%s==> %s%s\n' "$bold" "$*" "$reset"; }
skip() { printf '  %s· %s (identisch)%s\n' "$green" "$*" "$reset"; }
todo() { printf '  %s→ %s%s\n' "$yellow" "$*" "$reset"; }
fail() { printf '  %s✗ %s%s\n' "$red" "$*" "$reset"; }

[[ -f $MANIFEST ]] || { fail "manifest fehlt"; exit 1; }
((DRY)) && printf '%s*** TROCKENLAUF — es wird nichts verändert ***%s\n' "$bold$yellow" "$reset"

step "Dateien ausrollen"
ts=$(date +%Y%m%d-%H%M%S)
changed=0
while read -r src dst; do
  [[ -z ${src:-} || $src == \#* ]] && continue
  from="$REPO_DIR/$src"
  to="$HOME/$dst"
  [[ -f $from ]] || { fail "$src fehlt im Repo"; continue; }

  if [[ -f $to ]] && cmp -s "$from" "$to"; then
    skip "$dst"
    continue
  fi

  changed=1
  if [[ -f $to ]]; then
    todo "$dst (ersetzt, Backup: $dst.bak.$ts)"
    ((DRY)) || cp -p "$to" "$to.bak.$ts"
  else
    todo "$dst (neu)"
  fi
  if ((!DRY)); then
    mkdir -p "$(dirname "$to")"
    cp "$from" "$to"
    [[ $dst == .local/bin/* ]] && chmod +x "$to"
  fi
done < "$MANIFEST"
((changed)) || printf '  %sallen Dateien schon aktuell%s\n' "$green" "$reset"

step "Setup ausführen"
setup="$HOME/.local/bin/omarchy-setup-clone"
if ((DRY)); then
  todo "$setup --dry-run"
  [[ -x $setup ]] && "$setup" --dry-run || "$REPO_DIR/bin/omarchy-setup-clone" --dry-run
else
  "$setup"
fi

step "Hyprland neu laden"
if ((DRY)); then
  todo "hyprctl reload"
else
  hyprctl reload >/dev/null 2>&1 && printf '  %sok%s\n' "$green" "$reset" || fail "hyprctl reload fehlgeschlagen (läuft Hyprland?)"
  errs=$(hyprctl configerrors 2>/dev/null)
  [[ -n $errs && $errs != *"no errors"* ]] && { fail "Config-Fehler:"; printf '%s\n' "$errs"; }
fi

echo
