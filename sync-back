#!/bin/bash

# The other direction: copy the live system files back into the repo, so local
# edits can be committed. Needed because bootstrap copies instead of symlinking.
#
# Usage:
#   ./sync-back               # pull system state into the repo, then show git status

set -uo pipefail

REPO_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
MANIFEST="$REPO_DIR/manifest"

bold=$'\e[1m'; green=$'\e[32m'; yellow=$'\e[33m'; red=$'\e[31m'; reset=$'\e[0m'

[[ -f $MANIFEST ]] || { printf '%s✗ manifest fehlt%s\n' "$red" "$reset"; exit 1; }

printf '\n%s==> System -> Repo%s\n' "$bold" "$reset"
changed=0
while read -r src dst; do
  [[ -z ${src:-} || $src == \#* ]] && continue
  from="$HOME/$dst"
  to="$REPO_DIR/$src"
  if [[ ! -f $from ]]; then
    printf '  %s✗ %s fehlt auf dem System%s\n' "$red" "$dst" "$reset"
    continue
  fi
  if cmp -s "$from" "$to" 2>/dev/null; then
    printf '  %s· %s%s\n' "$green" "$src" "$reset"
  else
    printf '  %s→ %s aktualisiert%s\n' "$yellow" "$src" "$reset"
    cp "$from" "$to"
    changed=1
  fi
done < "$MANIFEST"

((changed)) || printf '  %snichts zu tun%s\n' "$green" "$reset"

printf '\n%s==> git status%s\n' "$bold" "$reset"
git -C "$REPO_DIR" status --short
printf '\nCommitten:  git -C %s add -A && git -C %s commit -m "..."\n\n' "$REPO_DIR" "$REPO_DIR"
